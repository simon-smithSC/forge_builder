      "700": { "$value": "#3e434e" },
      "800": { "$value": "#2b2f38" },
      "900": { "$value": "#1d2026" },
      "950": { "$value": "#14161b" },
      "1000": { "$value": "#0b0c0f" }
    },
    "ember": {
      "$description": "Secondary highlight, restrained ember amber. Progress and warm emphasis only.",
      "50": { "$value": "#fef7ec" },
      "100": { "$value": "#fdecd3" },
      "200": { "$value": "#fad9a5" },
      "300": { "$value": "#f6bf6b" },
      "400": { "$value": "#f0a03a" },
      "500": { "$value": "#e28417" },
      "600": { "$value": "#c2690e" },
      "700": { "$value": "#9c4f0c" },
      "800": { "$value": "#7c3d10" },
      "900": { "$value": "#66320f" },
      "950": { "$value": "#3d1c08" }
    },
    "danger": {
      "50": { "$value": "#fdeeed" },
      "100": { "$value": "#fbdcd9" },
      "200": { "$value": "#f5b7b1" },
      "300": { "$value": "#ec8b82" },
      "400": { "$value": "#e05e53" },
      "500": { "$value": "#cf3a2e" },
      "600": { "$value": "#b02b21" },
      "700": { "$value": "#8e221b" },
      "800": { "$value": "#711d18" },
      "900": { "$value": "#5c1a16" },
      "950": { "$value": "#380e0c" }
    },
    "success": {
      "50": { "$value": "#ecf8f0" },
      "100": { "$value": "#d5f0de" },
      "200": { "$value": "#aae0bf" },
      "300": { "$value": "#74cb98" },
      "400": { "$value": "#41b273" },
      "500": { "$value": "#219653" },
      "600": { "$value": "#177a43" },
      "700": { "$value": "#146137" },
      "800": { "$value": "#124d2e" },
      "900": { "$value": "#103f27" },
      "950": { "$value": "#082517" }
    },
    "warn": {
      "50": { "$value": "#fef8e7" },
      "100": { "$value": "#fdefc4" },
      "200": { "$value": "#fadd8a" },
      "300": { "$value": "#f4c44f" },
      "400": { "$value": "#eaa823" },
      "500": { "$value": "#d18a0f" },
      "600": { "$value": "#ab6c0a" },
      "700": { "$value": "#86520b" },
      "800": { "$value": "#6a400e" },
      "900": { "$value": "#57350e" },
      "950": { "$value": "#332006" }
    },
    "info": {
      "50": { "$value": "#ebf7fb" },
      "100": { "$value": "#d2edf6" },
      "200": { "$value": "#a4dbec" },
      "300": { "$value": "#6cc2dd" },
      "400": { "$value": "#38a5c8" },
      "500": { "$value": "#1c87ab" },
      "600": { "$value": "#146c8c" },
      "700": { "$value": "#125670" },
      "800": { "$value": "#114559" },
      "900": { "$value": "#0f3949" },
      "950": { "$value": "#08222c" }
    }
  },
  "space": {
    "$type": "dimension",
    "$description": "4px-base scale, emitted as rem (16px root).",
    "0": { "$value": "0rem" },
    "2": { "$value": "0.125rem" },
    "4": { "$value": "0.25rem" },
    "6": { "$value": "0.375rem" },
    "8": { "$value": "0.5rem" },
    "12": { "$value": "0.75rem" },
    "16": { "$value": "1rem" },
    "20": { "$value": "1.25rem" },
    "24": { "$value": "1.5rem" },
    "32": { "$value": "2rem" },
    "40": { "$value": "2.5rem" },
    "48": { "$value": "3rem" },
    "64": { "$value": "4rem" }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "sans": { "$value": ["Inter", "Segoe UI", "system-ui", "sans-serif"] },
      "mono": { "$value": ["JetBrains Mono", "SFMono-Regular", "Menlo", "Consolas", "monospace"] }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 }
    },
    "size": {
      "$type": "dimension",
      "$description": "Keys are px reference sizes; values are rem.",
      "11": { "$value": "0.6875rem" },
      "12": { "$value": "0.75rem" },
      "13": { "$value": "0.8125rem" },
      "14": { "$value": "0.875rem" },
      "16": { "$value": "1rem" },
      "18": { "$value": "1.125rem" },
      "22": { "$value": "1.375rem" },
      "28": { "$value": "1.75rem" }
    },
    "line": {
      "$type": "dimension",
      "$description": "Paired line heights for font.size keys.",
      "11": { "$value": "1rem" },
      "12": { "$value": "1rem" },
      "13": { "$value": "1.125rem" },
      "14": { "$value": "1.25rem" },
      "16": { "$value": "1.5rem" },
      "18": { "$value": "1.625rem" },
      "22": { "$value": "1.875rem" },
      "28": { "$value": "2.25rem" }
    },
    "tracking": {
      "$type": "dimension",
      "$description": "Inter reads better slightly tightened at chrome sizes (12-13px).",
      "tight": { "$value": "0.01em" },
      "normal": { "$value": "0em" }
    }
  },
  "radius": {
    "$type": "dimension",
    "xs": { "$value": "2px" },
    "sm": { "$value": "4px" },
    "md": { "$value": "6px" },
    "lg": { "$value": "10px" },
    "xl": { "$value": "16px" },
    "full": { "$value": "999px" }
  },
  "elevation": {
    "$type": "shadow",
    "$description": "Layered depth: border-tint + key + ambient, neutral-tinted (#14161b), opacity falls as blur grows. 0 canvas, 1 cards, 2 raised controls/sticky, 3 popovers/menus, 4 dialogs/drawer/toasts.",
    "0": {
      "$value": [
        { "color": "#14161b0f", "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "1px" }
      ]
    },
    "1": {
      "$value": [
        { "color": "#14161b0d", "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "1px" },
        { "color": "#14161b12", "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px" },
        { "color": "#14161b0d", "offsetX": "0px", "offsetY": "2px", "blur": "6px", "spread": "0px" }
      ]
    },
    "2": {
      "$value": [
        { "color": "#14161b0d", "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "1px" },
        { "color": "#14161b14", "offsetX": "0px", "offsetY": "2px", "blur": "4px", "spread": "0px" },
        { "color": "#14161b0f", "offsetX": "0px", "offsetY": "4px", "blur": "12px", "spread": "0px" }
      ]
    },
    "3": {
      "$value": [
        { "color": "#14161b0a", "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "1px" },
        { "color": "#14161b17", "offsetX": "0px", "offsetY": "4px", "blur": "8px", "spread": "0px" },
        { "color": "#14161b14", "offsetX": "0px", "offsetY": "8px", "blur": "24px", "spread": "0px" }
      ]
    },
    "4": {
      "$value": [
        { "color": "#14161b0a", "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "1px" },
        { "color": "#14161b1a", "offsetX": "0px", "offsetY": "8px", "blur": "16px", "spread": "0px" },
        { "color": "#14161b1f", "offsetX": "0px", "offsetY": "16px", "blur": "48px", "spread": "0px" }
      ]
    }
  },
  "duration": {
    "$type": "duration",
    "$description": "Decisive motion. Exits run faster than enters.",
    "80": { "$value": "80ms" },
    "120": { "$value": "120ms" },
    "160": { "$value": "160ms" },
    "200": { "$value": "200ms" },
    "280": { "$value": "280ms" }
  },
  "ease": {
    "$type": "cubicBezier",
    "standard": { "$value": [0.2, 0, 0.2, 1] },
    "enter": { "$value": [0.1, 0.8, 0.2, 1] },
    "exit": { "$value": [0.4, 0, 1, 1] },
    "spring": { "$value": [0.3, 1.4, 0.4, 1] }
  },
  "z": {
    "$type": "number",
    "base": { "$value": 0 },
    "raised": { "$value": 10 },
    "sticky": { "$value": 100 },
    "overlay": { "$value": 700 },
    "modal": { "$value": 800 },
    "toast": { "$value": 900 }
  }
}
