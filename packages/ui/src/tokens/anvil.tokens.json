{
  "$description": "Anvil design tokens: primitive tier, W3C DTCG format (2025.10). Source of truth; build.ts emits src/anvil.css and src/tokens.ts. Never edit the generated files.",
  "color": {
    "$type": "color",
    "cobalt": {
      "$description": "Primary ramp. Deep cobalt, evolved from #1f6feb toward more saturation and depth.",
      "50": { "$value": "#eef4fe" },
      "100": { "$value": "#d9e6fd" },
      "200": { "$value": "#b6cdfb" },
      "300": { "$value": "#8badf7" },
      "400": { "$value": "#5c88f0" },
      "500": { "$value": "#3366e6" },
      "600": { "$value": "#2451d4" },
      "700": { "$value": "#1d41b0" },
      "800": { "$value": "#19368c" },
      "900": { "$value": "#162c6e" },
      "950": { "$value": "#0e1b46" }
    },
    "neutral": {
      "$description": "Steel grays with a slight cool cast.",
      "0": { "$value": "#ffffff" },
      "50": { "$value": "#f6f7f9" },
      "100": { "$value": "#eceef2" },
      "200": { "$value": "#dfe2e8" },
      "300": { "$value": "#c9cdd6" },
      "400": { "$value": "#9aa1ad" },
      "500": { "$value": "#6e7683" },
      "600": { "$value": "#545b67" },
      "700": { "$value": "#3e434e" },
      "800": { "$value": "#2b2f38" },
      "900": { "$value": "#1d2026" },
      "950": { "$value": "#14161b" },
      "1000": { "$value": "#0b0c0f" }
    },
    "ember": {
      "$description": "Secondary highlight, restrained ember amber. Progress and warm emphasis only.",
      "50": { "$value": "#fef7ec" },
      "100": { "$value": "#fdecd3" },
      "200": { "$value": "#fad9a5" },
      "300": { "$value": "#f6bf6b" },
      "400": { "$value": "#f0a03a" },
      "500": { "$value": "#e28417" },
      "600": { "$value": "#c2690e" },
      "700": { "$value": "#9c4f0c" },
      "800": { "$value": "#7c3d10" },
      "900": { "$value": "#66320f" },
      "950": { "$value": "#3d1c08" }
    },
    "danger": {
      "50": { "$value": "#fdeeed" },
      "100": { "$value": "#fbdcd9" },
      "200": { "$value": "#f5b7b1" },
      "300": { "$value": "#ec8b82" },
      "400": { "$value": "#e05e53" },
      "500": { "$value": "#cf3a2e" },
      "600": { "$value": "#b02b21" },
      "700": { "$value": "#8e221b" },
      "800": { "$value": "#711d18" },
      "900": { "$value": "#5c1a16" },
      "950": { "$value": "#380e0c" }
    },
    "success": {
      "50": { "$value": "#ecf8f0" },
      "100": { "$value": "#d5f0de" },
      "200": { "$value": "#aae0bf" },
      "300": { "$value": "#74cb98" },
      "400": { "$value": "#41b273" },
      "500": { "$value": "#219653" },
      "600": { "$value": "#177a43" },
      "700": { "$value": "#146137" },
      "800": { "$value": "#124d2e" },
      "900": { "$value": "#103f27" },
      "950": { "$value": "#082517" }
    },
    "warn": {
      "50": { "$value": "#fef8e7" },
      "100": { "$value": "#fdefc4" },
      "200": { "$value": "#fadd8a" },
      "300": { "$value": "#f4c44f" },
      "400": { "$value": "#eaa823" },
      "500": { "$value": "#d18a0f" },
      "600": { "$value": "#ab6c0a" },
      "700": { "$value": "#86520b" },
      "800": { "$value": "#6a400e" },
      "900": { "$value": "#57350e" },
      "950": { "$value": "#332006" }
    },
    "info": {
      "50": { "$value": "#ebf7fb" },
      "100": { "$value": "#d2edf6" },
      "200": { "$value": "#a4dbec" },
      "300": { "$value": "#6cc2dd" },
      "400": { "$value": "#38a5c8" },
      "500": { "$value": "#1c87ab" },
      "600": { "$value": "#146c8c" },
      "700": { "$value": "#125670" },
      "800": { "$value": "#114559" },
      "900": { "$value": "#0f3949" },
      "950": { "$value": "#08222c" }
    }
  },
  "space": {
    "$type": "dimension",
    "$description": "4px-base scale, emitted as rem (16px root).",
    "0": { "$value": "0rem" },
    "2": { "$value": "0.125rem" },
    "4": { "$value": "0.25rem" },
    "6": { "$value": "0.375rem" },
    "8": { "$value": "0.5rem" },
    "12": { "$value": "0.75rem" },
    "16": { "$value": "1rem" },
    "20": { "$value": "1.25rem" },
    "24": { "$value": "1.5rem" },
    "32": { "$value": "2rem" },
    "40": { "$value": "2.5rem" },
    "48": { "$value": "3rem" },
    "64": { "$value": "4rem" }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "$description": "Geist Sans is the Anvil UI face (variable woff2, vendored via scripts/fetch-fonts.mjs). The Fallback faces are metric-adjusted local stacks declared in src/fonts.css so text does not reflow when the webfont lands.",
      "sans": { "$value": ["Geist Sans", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "Roboto", "Helvetica", "Arial", "sans-serif"] },
      "mono": { "$value": ["JetBrains Mono", "SFMono-Regular", "Menlo", "Consolas", "monospace"] }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold": { "$value": 700 }
    },
    "size": {
      "$type": "dimension",
      "$description": "Keys are px reference sizes; values are rem. 12px is the system floor: nothing in Anvil or consuming chrome may render smaller.",
      "12": { "$value": "0.75rem" },
      "13": { "$value": "0.8125rem" },
      "14": { "$value": "0.875rem" },
      "16": { "$value": "1rem" },
      "18": { "$value": "1.125rem" },
      "20": { "$value": "1.25rem" },
      "22": { "$value": "1.375rem" },
      "24": { "$value": "1.5rem" },
      "28": { "$value": "1.75rem" },
      "32": { "$value": "2rem" },
      "40": { "$value": "2.5rem" }
    },
    "line": {
      "$type": "dimension",
      "$description": "Paired line heights for font.size keys.",
      "12": { "$value": "1.125rem" },
      "13": { "$value": "1.125rem" },
      "14": { "$value": "1.25rem" },
      "16": { "$value": "1.5rem" },
      "18": { "$value": "1.75rem" },
      "20": { "$value": "1.75rem" },
      "22": { "$value": "1.875rem" },
      "24": { "$value": "2rem" },
      "28": { "$value": "2.25rem" },
      "32": { "$value": "2.5rem" },
      "40": { "$value": "3rem" }
    },
    "tracking": {
      "$type": "dimension",
      "$description": "Geist reads best slightly tightened at display/heading sizes; body and small labels stay neutral.",
      "tight": { "$value": "-0.01em" },
      "normal": { "$value": "0em" }
    }
  },
  "type": {
    "$type": "typography",
    "$description": "Role scale (Base-style: display / heading / label / paragraph / mono). Each role is a complete setting: px-referenced size, line-height, weight, tracking. Emitted as --an-type-<role>-* custom properties plus .an-type-<role> utility classes. UI paragraph floor is 14px, label floor 13px, absolute floor 12px.",
    "displayLarge": {
      "$value": { "fontFamily": "{font.family.sans}", "fontSize": "2.5rem", "lineHeight": "3rem", "fontWeight": 700, "letterSpacing": "-0.02em" }
    },
    "display": {
      "$value": { "fontFamily": "{font.family.sans}", "fontSize": "2rem", "lineHeight": "2.5rem", "fontWeight": 700, "letterSpacing": "-0.02em" }
    },
    "headingLarge": {
      "$value": { "fontFamily": "{font.family.sans}", "fontSize": "1.5rem", "lineHeight": "2rem", "fontWeight": 600, "letterSpacing": "-0.015em" }
    },
    "heading": {
      "$value": { "fontFamily": "{font.family.sans}", "fontSize": "1.25rem", "lineHeight": "1.75rem", "fontWeight": 600, "letterSpacing": "-0.01em" }
    },
    "headingSmall": {
      "$value": { "fontFamily": "{font.family.sans}", "fontSize": "1rem", "lineHeight": "1.5rem", "fontWeight": 600, "letterSpacing": "-0.005em" }
    },
    "labelLarge": {
      "$value": { "fontFamily": "{font.family.sans}", "fontSize": "1rem", "lineHeight": "1.5rem", "fontWeight": 500, "letterSpacing": "0em" }
    },
    "label": {
      "$value": { "fontFamily": "{font.family.sans}", "fontSize": "0.875rem", "lineHeight": "1.25rem", "fontWeight": 500, "letterSpacing": "0em" }
    },
    "labelSmall": {
      "$value": { "fontFamily": "{font.family.sans}", "fontSize": "0.8125rem", "lineHeight": "1.125rem", "fontWeight": 500, "letterSpacing": "0.01em" }
    },
    "paragraphLarge": {
      "$value": { "fontFamily": "{font.family.sans}", "fontSize": "1.125rem", "lineHeight": "1.75rem", "fontWeight": 400, "letterSpacing": "0em" }
    },
    "paragraph": {
      "$value": { "fontFamily": "{font.family.sans}", "fontSize": "1rem", "lineHeight": "1.5rem", "fontWeight": 400, "letterSpacing": "0em" }
    },
    "paragraphSmall": {
      "$value": { "fontFamily": "{font.family.sans}", "fontSize": "0.875rem", "lineHeight": "1.25rem", "fontWeight": 400, "letterSpacing": "0em" }
    },
    "mono": {
      "$value": { "fontFamily": "{font.family.mono}", "fontSize": "0.8125rem", "lineHeight": "1.25rem", "fontWeight": 400, "letterSpacing": "0em" }
    }
  },
  "icon": {
    "$description": "Icon sizing convention (Base-style): 16 inline with text, 20 default controls, 24 emphasis/empty states. Stroke width 2 at all sizes (Lucide grid).",
    "size": {
      "$type": "dimension",
      "16": { "$value": "16px" },
      "20": { "$value": "20px" },
      "24": { "$value": "24px" }
    },
    "stroke": {
      "$type": "number",
      "regular": { "$value": 2 }
    }
  },
  "radius": {
    "$type": "dimension",
    "xs": { "$value": "2px" },
    "sm": { "$value": "4px" },
    "md": { "$value": "6px" },
    "lg": { "$value": "10px" },
    "xl": { "$value": "16px" },
    "full": { "$value": "999px" }
  },
  "elevation": {
    "$type": "shadow",
    "$description": "Layered depth: border-tint + key + ambient, neutral-tinted (#14161b), opacity falls as blur grows. 0 canvas, 1 cards, 2 raised controls/sticky, 3 popovers/menus, 4 dialogs/drawer/toasts.",
    "0": {
      "$value": [
        { "color": "#14161b0f", "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "1px" }
      ]
    },
    "1": {
      "$value": [
        { "color": "#14161b0d", "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "1px" },
        { "color": "#14161b12", "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px" },
        { "color": "#14161b0d", "offsetX": "0px", "offsetY": "2px", "blur": "6px", "spread": "0px" }
      ]
    },
    "2": {
      "$value": [
        { "color": "#14161b0d", "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "1px" },
        { "color": "#14161b14", "offsetX": "0px", "offsetY": "2px", "blur": "4px", "spread": "0px" },
        { "color": "#14161b0f", "offsetX": "0px", "offsetY": "4px", "blur": "12px", "spread": "0px" }
      ]
    },
    "3": {
      "$value": [
        { "color": "#14161b0a", "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "1px" },
        { "color": "#14161b17", "offsetX": "0px", "offsetY": "4px", "blur": "8px", "spread": "0px" },
        { "color": "#14161b14", "offsetX": "0px", "offsetY": "8px", "blur": "24px", "spread": "0px" }
      ]
    },
    "4": {
      "$value": [
        { "color": "#14161b0a", "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "1px" },
        { "color": "#14161b1a", "offsetX": "0px", "offsetY": "8px", "blur": "16px", "spread": "0px" },
        { "color": "#14161b1f", "offsetX": "0px", "offsetY": "16px", "blur": "48px", "spread": "0px" }
      ]
    },
    "dark": {
      "$description": "5B.1 dark-theme remap, geometry identical per level: the border-tint ring becomes a light inner keyline (#ffffff12, i.e. rgba(255,255,255,0.07)) because dark surfaces cannot cast a darker ring, and key/ambient alphas deepen ~1.5x so depth survives on near-black. Emitted via the semantic maps in build.ts, never as extra --an-elevation-* names.",
      "0": {
        "$value": [
          { "color": "#ffffff12", "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "1px" }
        ]
      },
      "1": {
        "$value": [
          { "color": "#ffffff12", "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "1px" },
          { "color": "#14161b1b", "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px" },
          { "color": "#14161b14", "offsetX": "0px", "offsetY": "2px", "blur": "6px", "spread": "0px" }
        ]
      },
      "2": {
        "$value": [
          { "color": "#ffffff12", "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "1px" },
          { "color": "#14161b1e", "offsetX": "0px", "offsetY": "2px", "blur": "4px", "spread": "0px" },
          { "color": "#14161b17", "offsetX": "0px", "offsetY": "4px", "blur": "12px", "spread": "0px" }
        ]
      },
      "3": {
        "$value": [
          { "color": "#ffffff12", "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "1px" },
          { "color": "#14161b23", "offsetX": "0px", "offsetY": "4px", "blur": "8px", "spread": "0px" },
          { "color": "#14161b1e", "offsetX": "0px", "offsetY": "8px", "blur": "24px", "spread": "0px" }
        ]
      },
      "4": {
        "$value": [
          { "color": "#ffffff12", "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "1px" },
          { "color": "#14161b27", "offsetX": "0px", "offsetY": "8px", "blur": "16px", "spread": "0px" },
          { "color": "#14161b2f", "offsetX": "0px", "offsetY": "16px", "blur": "48px", "spread": "0px" }
        ]
      }
    }
  },
  "bevel": {
    "$type": "shadow",
    "$description": "Machined-edge insets for solid-fill controls (5A.3): a 1px top highlight plus a 1px bottom edge, composed UNDER an elevation level (bevel-highlight, bevel-edge, elevation-N). Full gradient fills were rejected (banding); near-flat + bevel is the Base/Linear treatment.",
    "highlight": {
      "$value": [
        { "color": "#ffffff24", "offsetX": "0px", "offsetY": "1px", "blur": "0px", "spread": "0px", "inset": true }
      ]
    },
    "edge": {
      "$value": [
        { "color": "#14161b2e", "offsetX": "0px", "offsetY": "-1px", "blur": "0px", "spread": "0px", "inset": true }
      ]
    }
  },
  "duration": {
    "$type": "duration",
    "$description": "Decisive motion. Exits run faster than enters.",
    "80": { "$value": "80ms" },
    "120": { "$value": "120ms" },
    "160": { "$value": "160ms" },
    "200": { "$value": "200ms" },
    "280": { "$value": "280ms" }
  },
  "ease": {
    "$type": "cubicBezier",
    "standard": { "$value": [0.2, 0, 0.2, 1] },
    "enter": { "$value": [0.1, 0.8, 0.2, 1] },
    "exit": { "$value": [0.4, 0, 1, 1] },
    "spring": { "$value": [0.3, 1.4, 0.4, 1] }
  },
  "z": {
    "$type": "number",
    "base": { "$value": 0 },
    "raised": { "$value": 10 },
    "sticky": { "$value": 100 },
    "overlay": { "$value": 700 },
    "modal": { "$value": 800 },
    "toast": { "$value": 900 }
  }
}
